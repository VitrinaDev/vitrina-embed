{
  "name": "@vitrinadev/widget",
  "version": "0.0.0",
  "description": "Vitrina embeddable chat widget for dealer websites.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": "./dist/loader.global.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'lint: no-op (typecheck + tests are the hard gate)' && exit 0"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
