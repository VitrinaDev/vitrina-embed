{
  "name": "@vitrinadev/widget",
  "version": "0.1.0",
  "description": "Vitrina embeddable chat widget for dealer websites — shadow-DOM UI, real-time SSE, publishable origin-locked key.",
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": "./dist/loader.global.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vitrina",
    "chat",
    "widget",
    "embed",
    "chat-widget",
    "shadow-dom",
    "sse",
    "dealer",
    "automotive",
    "livechat"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitrinaDev/vitrina-embed.git",
    "directory": "packages/widget"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'lint: no-op (typecheck + tests are the hard gate)' && exit 0"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
